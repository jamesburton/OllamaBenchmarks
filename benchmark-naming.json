      "jacob-ebey/phi4-tools:latest": "jacob-ebey_phi4-tools",
      "hf.co/bartowski/Tesslate_OmniCoder-9B-GGUF:Q4_K_M": "hf.co_bartowski_Tesslate_OmniCoder-9B-GGUF_Q4_K_M",
      "hf.co/bartowski/nvidia_NVIDIA-Nemotron-Nano-9B-v2-GGUF:Q4_K_M": "hf.co_bartowski_nvidia_NVIDIA-Nemotron-Nano-9B-v2-GGUF_Q4_K_M",
      "nemotron-nano-9b-v2_q4_k_m": "hf.co_bartowski_nvidia_NVIDIA-Nemotron-Nano-9B-v2-GGUF_Q4_K_M",
