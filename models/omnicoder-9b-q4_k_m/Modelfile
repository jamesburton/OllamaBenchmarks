# OmniCoder-9B with Qwen3.5 renderer/parser for tool calling support.
# The HF GGUF lacks RENDERER/PARSER directives needed for structured tool calls.
# OmniCoder is a Qwen3.5-9B fine-tune, so we use the qwen3.5 renderer.
FROM hf.co/Tesslate/OmniCoder-9B-GGUF:Q4_K_M

TEMPLATE {{ .Prompt }}
RENDERER qwen3.5
PARSER qwen3.5

PARAMETER num_ctx 4096
PARAMETER num_batch 64
PARAMETER temperature 0
